<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>mcp-token-report</AssemblyName>
    <RootNamespace>McpIt.TokenReport.Tool</RootNamespace>

    <!-- Publish as a .NET global/local tool: dotnet tool install -g McpIt.TokenReport.Tool -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>mcp-token-report</ToolCommandName>
    <PackageId>McpIt.TokenReport.Tool</PackageId>
    <Description>Offline token-cost analyzer for MCP servers. Reports what your MCP tools/list costs the model, with a CI budget gate. Part of McpIt.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\McpIt.TokenReport\McpIt.TokenReport.csproj" />
  </ItemGroup>

</Project>
