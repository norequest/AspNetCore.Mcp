<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <!-- Public attributes intentionally live in the `AspNetCore.Mcp` namespace (clean
         `using AspNetCore.Mcp;` API), not `AspNetCore.Mcp.Abstractions`. RootNamespace makes
         that the tooling-expected namespace so IDE "adjust namespaces" won't move them. -->
    <RootNamespace>AspNetCore.Mcp</RootNamespace>
  </PropertyGroup>

</Project>
